# BridgeFi Environment Variables
# Copy this file to .env and fill in your values

# Flask secret key (change in production)
SECRET_KEY=bridgefi-secret-key-change-in-prod

# Anthropic API Key (optional — app works without it using mock data)
# Get yours from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Database URL (defaults to SQLite — no setup needed)
# DATABASE_URL=sqlite:///bridgefi.db

# Port (defaults to 5000)
# PORT=5000

# Debug mode
FLASK_DEBUG=true
